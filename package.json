{
  "name": "w17-ground-station",
  "version": "0.1.0",
  "description": "Viewer-only FPV ground station for the W17 RC car: WebRTC video + gamepad-mirrored HUD + telemetry overlay.",
  "main": "main/main.js",
  "scripts": {
    "setup": "node scripts/ensure-electron.js && node scripts/fetch-mediamtx.js",
    "start": "node scripts/run.js",
    "demo": "node scripts/run.js --demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "electron-builder --win",
    "fetch-mediamtx": "node scripts/fetch-mediamtx.js"
  },
  "author": "Vitaliy Khomenko",
  "license": "MIT",
  "optionalDependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vitest": "^2.0.0"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
